# EAS Voice Controller — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# No API keys required — everything runs locally.

# ── Serial ────────────────────────────────────────────────────────────────────
# Port the ESP32 is connected to.
# Windows example:   COM3
# Linux/Mac example: /dev/ttyACM0
SERIAL_PORT=COM3

# Optional microphone selection for wake-word listening.
# Leave blank to use OS default, then auto-fallback to first input device.
# You can set either a numeric index (e.g. 2) or part of a device name.
AUDIO_INPUT_DEVICE=

# ── Wake Word ─────────────────────────────────────────────────────────────────
# Built-in choices: hey_jarvis, alexa, hey_mycroft, timer, weather
WAKE_WORD_MODEL=hey_jarvis

# Confidence threshold (0.0–1.0). Lower = more sensitive / more false triggers.
WAKE_WORD_THRESHOLD=0.5

# ── Whisper STT ───────────────────────────────────────────────────────────────
# Model size: tiny, base, small, medium, large
# Larger = more accurate but slower. 'base' is a good starting point.
WHISPER_MODEL=base

# ── Ollama LLM ────────────────────────────────────────────────────────────────
# Ollama must be running before starting main.py.
# Install: https://ollama.com
# Pull a model first, e.g.:  ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Piper TTS ─────────────────────────────────────────────────────────────────
# Download a voice model from: https://github.com/rhasspy/piper/releases
# Place the .onnx file AND its .onnx.json config file in pc_host/models/
# Recommended voice: en_US-lessac-medium  (good balance of speed and quality)
PIPER_MODEL_PATH=models/en_US-lessac-medium.onnx
